{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for open-broadcast-encoder",
  "windows": ["main"],
  "permissions": [
    "core:app:allow-app-hide",
    "core:app:allow-app-show",
    "core:app:allow-app-exit",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-open"
  ]
}
